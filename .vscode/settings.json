{
	/*
		Editor settings
	*/
	"editor.formatOnSave": true,
	"editor.formatOnType": false,
	"editor.formatOnPaste": false,
	// https://marketplace.visualstudio.com/items?itemName=esbenp.prettier-vscode
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"editor.detectIndentation": false,
	"editor.tabSize": 4,
	"editor.renderWhitespace": "boundary",
	"editor.codeActionsOnSave": {
		"source.fixAll": "explicit"
	},

	/*
		Prettier settings
	*/
	"prettier.useEditorConfig": true,
	"prettier.configPath": ".prettierrc",

	/*
		Files settings
	*/
	"files.eol": "\n",
	"files.encoding": "utf8",
	"files.trimTrailingWhitespace": true,
	"files.insertFinalNewline": false,
	"files.associations": {
		"*.Brewfile": "ruby",
		"*.cron": "shellscript",
		"*.lib": "shellscript",
		"*yaml.tftpl": "jinja-yaml",
		"*json.tftpl": "jinja-json",
		"LICENSE": "plaintext",
		"CODEOWNERS": "properties"
	},
	"files.exclude": {
		"**/.git": true,
		"**/.DS_Store": true,
		"**/node_modules": true,
		"**/dist": true,
		"**/build": true,
		"**/__pycache__": true,
		"**/.venv": true,
		"**/*.tfstate": true,
		"**/*.tfstate.*": true,
		"**/.terraform": true,
		".terraform.lock.hcl": true
	},

	/*
		Terminal settings
	*/
	"terminal.integrated.defaultProfile.osx": "bash",
	"terminal.integrated.profiles.osx": {
		"bash": {
			"path": "${env:SHELL}",
			"icon": "terminal",
			"color": "terminal.ansiGreen"
		},
		"sh": {
			"path": "/bin/sh",
			"icon": "terminal-linux",
			"color": "terminal.ansiYellow",
			"overrideName": true
		}
	},

	/*
		Git settings
	*/
	"git.autofetch": true,
	"git.enableSmartCommit": true,
	"git.confirmSync": false,

	/*
		YAML settings
		Leave commented to use prettier for YAML formatting instead of redhat.vscode-yaml -- recommended to avoid conflicts between formatters
	*/
	// "[yaml]": {
	// 	"editor.defaultFormatter": "redhat.vscode-yaml",
	// 	"editor.formatOnSave": true
	// },

	/*
		Markdown settings
	*/
	"[markdown]": {
		"editor.defaultFormatter": "yzhang.markdown-all-in-one",
		"editor.formatOnSave": true,
		"editor.formatOnPaste": true,
		"editor.codeActionsOnSave": {
			"source.fixAll.markdownlint": "explicit"
		}
	},
	// https://github.com/yzhang-gh/vscode-markdown?tab=readme-ov-file#supported-settings
	"markdown.extension.orderedList.marker": "one",
	"markdown.extension.toc.unorderedList.marker": "-"
}
